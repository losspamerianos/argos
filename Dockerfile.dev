FROM node:22-alpine

# node:22-alpine ships a pre-existing `node` user/group at uid/gid 1000.
# Run as that user so files written into the bind-mounted source tree are
# owned by the host's uid 1000 rather than silently becoming root.
WORKDIR /app

# Pre-create the pnpm content-addressed store mount point with correct
# ownership; the named volume inherits this on first mount. /app/node_modules
# does not need pre-creation here — its named volume gets ownership applied
# automatically by Docker, and recursive chown on /app would touch the (then
# unmounted) bind mount target.
RUN mkdir -p /pnpm-store && chown node:node /pnpm-store

# corepack lives in /usr/local/bin and needs root to install the pnpm shim.
RUN corepack enable

USER node

EXPOSE 5173

# Compose `init: true` provides docker-init (tini under the hood) as PID 1
# for proper signal handling and zombie reaping; do not duplicate.
CMD ["pnpm", "dev"]
