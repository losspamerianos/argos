# ARGOS environment configuration.
# Copy to .env and fill with local values. Variables marked REQUIRED have no
# safe defaults — compose will refuse to start without them.

# --- Database (REQUIRED) ---
POSTGRES_USER=argos
POSTGRES_PASSWORD=CHANGE_ME_BEFORE_FIRST_START
POSTGRES_DB=argos

# DATABASE_URL is composed from the above by docker-compose; override here
# only when running outside Docker (e.g. `pnpm db:generate` from the host).
# DATABASE_URL=postgres://argos:argos@localhost:5432/argos

# Set to 'require' to force TLS on the Postgres connection (production).
PGSSL=

# --- Auth: ES256 JWT keys ---
JWT_PRIVATE_KEY_PATH=/app/keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=/app/keys/jwt-public.pem
# 15 minutes
JWT_ACCESS_TTL_SECONDS=900
# 30 days
JWT_REFRESH_TTL_SECONDS=2592000
JWT_ISSUER=argos
JWT_AUDIENCE=argos
JWT_KID=v1

# --- Cookies ---
# Set to 'true' in production. Drives both the Secure flag and the __Secure-
# cookie name prefix. Independent of NODE_ENV so it cannot silently regress
# behind a misconfigured proxy.
COOKIES_SECURE=false

# --- Platform ---
NODE_ENV=development
PLATFORM_DEFAULT_LOCALE=en

# --- Map fallback (used when an Operation has no AO override) ---
MAP_DEFAULT_CENTER_LON=33.6694
MAP_DEFAULT_CENTER_LAT=34.9787
MAP_DEFAULT_ZOOM=12

# --- Dev tweaks ---
# Set to 1 only when inotify cannot reach the bind mount (macOS, WSL).
# On native Linux Docker, polling burns CPU.
VITE_USE_POLLING=0

# --- Edge / Caddy (optional; opt-in via `docker compose --profile edge up`) ---
# Public origin the app reports to the browser; must match what Caddy serves.
# Leave at localhost when no reverse proxy is in front.
ARGOS_PUBLIC_ORIGIN=http://localhost:5173
# Set to 1 when behind a reverse proxy that adds X-Forwarded-Proto. Off by
# default so a direct hit can't spoof scheme in the Origin check.
TRUST_PROXY=0
# Comma-separated hostnames Vite will accept (v5 requires explicit allowlist
# for hosts other than `localhost`).
VITE_ALLOWED_HOSTS=
# Bcrypt hash of the Basic-Auth password. Generate with:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext '...'
# Replace single `$` chars with `$$` so docker-compose's interpolation passes
# them through unmodified.
CADDY_BASIC_AUTH_HASH=
