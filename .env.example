# ARGOS environment configuration
# Copy to .env and fill with local values.

# --- Database ---
DATABASE_URL=postgres://argos:argos@db:5432/argos

# --- Auth: ES256 JWT keys ---
# Generated via scripts/gen-keys.sh; never commit the private key.
JWT_PRIVATE_KEY_PATH=/app/keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=/app/keys/jwt-public.pem
JWT_ACCESS_TTL_SECONDS=900           # 15 min
JWT_REFRESH_TTL_SECONDS=2592000      # 30 days
JWT_ISSUER=argos
JWT_AUDIENCE=argos

# --- Platform ---
NODE_ENV=development
PLATFORM_DEFAULT_LOCALE=en

# --- Map fallback (used only if an Operation has no AO override) ---
MAP_DEFAULT_CENTER_LON=33.6694
MAP_DEFAULT_CENTER_LAT=34.9787
MAP_DEFAULT_ZOOM=12
