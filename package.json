{
  "name": "argos",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "ARGOS – Animal Registry & Geographical Operations System. TNR Lifecycle Operating System.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/losspamerianos/argos.git"
  },
  "bugs": {
    "url": "https://github.com/losspamerianos/argos/issues"
  },
  "homepage": "https://github.com/losspamerianos/argos#readme",
  "author": "Nine Lives Operations",
  "scripts": {
    "dev": "vite dev --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "keys:gen": "bash scripts/gen-keys.sh",
    "test": "echo 'no tests yet' && exit 0"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "@sveltejs/adapter-node": "^5.2.0",
    "@sveltejs/kit": "^2.8.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.10.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^2.45.0",
    "globals": "^15.9.0",
    "prettier": "^3.3.0",
    "prettier-plugin-svelte": "^3.2.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.5.0",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.0",
    "drizzle-orm": "^0.36.0",
    "jose": "^5.9.0",
    "maplibre-gl": "^4.7.0",
    "postgres": "^3.4.0"
  },
  "packageManager": "pnpm@9.12.0"
